TRUSTED_PORTAL_SECRET_KEY=change-me
TRUSTED_PORTAL_DEBUG=true
TRUSTED_PORTAL_ALLOWED_HOSTS=localhost,127.0.0.1
TRUSTED_PORTAL_TIME_ZONE=Asia/Seoul
TRUSTED_PORTAL_LOG_DIR=/path/to/trusted_portal/.runtime/logs
TRUSTED_PORTAL_LOG_LEVEL=INFO
THEPEACH_BASE_URL=https://thepeach.thesysm.com
THEPEACH_FALLBACK_BASE_URLS=http://localhost:8000,http://localhost:8001
THEPEACH_AUTH_LOGIN_PATH=/api/v1/auth/login/
THEPEACH_AUTH_ME_PATH=/api/v1/auth/me/
THEPEACH_AUTH_TIMEOUT_SECONDS=3.0
THEPEACH_SESSION_TOKEN_KEY=thepeach_access_token
THEPEACH_FORWARD_HEADERS=X-Request-ID
